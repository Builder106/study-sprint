    "@radix-ui/react-navigation-menu": "npm:@radix-ui/react-navigation-menu@1.2.5",
    "@radix-ui/react-popover": "npm:@radix-ui/react-popover@1.1.6",
    "@radix-ui/react-progress": "npm:@radix-ui/react-progress@1.1.2",
    "@radix-ui/react-radio-group": "npm:@radix-ui/react-radio-group@1.2.3",
    "@radix-ui/react-scroll-area": "npm:@radix-ui/react-scroll-area@1.2.3",
