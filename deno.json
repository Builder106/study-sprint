    "@radix-ui/react-tooltip": "npm:@radix-ui/react-tooltip@1.1.8",
    "@supabase/supabase-js": "npm:@supabase/supabase-js@2.105.3",
    "@vercel/analytics": "npm:@vercel/analytics@1.4.1",
    "canvas-confetti": "npm:canvas-confetti@1.9.4",
    "class-variance-authority": "npm:class-variance-authority@0.7.1",
