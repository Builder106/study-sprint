{
  "tasks": {
    "dev": "deno run -A npm:vite",
    "build": "deno run -A npm:vite build",
    "preview": "deno run -A npm:vite preview",
    "check": "deno run -A npm:typescript/tsc --noEmit",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check",
    "lint": "deno lint supabase/functions/syllabus-parse supabase/functions/google-calendar",

    "test": "node ./node_modules/.bin/bddgen && node ./node_modules/.bin/playwright test",
    "test:e2e": "deno task test",
    "test:e2e:ui": "node ./node_modules/.bin/bddgen && node ./node_modules/.bin/playwright test --ui",
    "test:setup": "deno run -A e2e/setup/bootstrap-demo.ts",
    "demo": "DEMO=1 node ./node_modules/.bin/bddgen --config playwright.demo.config.ts && DEMO=1 node ./node_modules/.bin/playwright test --config playwright.demo.config.ts",
    "demo:light": "DEMO=1 DEMO_THEME=light node ./node_modules/.bin/bddgen --config playwright.demo.config.ts && DEMO=1 DEMO_THEME=light node ./node_modules/.bin/playwright test --config playwright.demo.config.ts",
    "demo:both": "deno task demo && deno task demo:light",
    "gif": "deno run -A scripts/videos-to-gifs.ts",
    "social-card": "deno run -A scripts/render-social-card.ts",

    "supabase:link": "deno run -A npm:supabase link",
    "supabase:db:push": "deno run -A npm:supabase db push",
    "supabase:functions:deploy": "deno run -A npm:supabase functions deploy syllabus-parse google-calendar",
    "supabase:functions:serve": "deno run -A npm:supabase functions serve"
  },
  "imports": {
    "@emotion/react": "npm:@emotion/react@11.14.0",
    "@emotion/styled": "npm:@emotion/styled@11.14.1",
    "@mui/icons-material": "npm:@mui/icons-material@7.3.5",
    "@mui/material": "npm:@mui/material@7.3.5",
    "@popperjs/core": "npm:@popperjs/core@2.11.8",
    "@radix-ui/react-accordion": "npm:@radix-ui/react-accordion@1.2.3",
    "@radix-ui/react-alert-dialog": "npm:@radix-ui/react-alert-dialog@1.1.6",
    "@radix-ui/react-aspect-ratio": "npm:@radix-ui/react-aspect-ratio@1.1.2",
    "@radix-ui/react-avatar": "npm:@radix-ui/react-avatar@1.1.3",
    "@radix-ui/react-checkbox": "npm:@radix-ui/react-checkbox@1.1.4",
    "@radix-ui/react-collapsible": "npm:@radix-ui/react-collapsible@1.1.3",
    "@radix-ui/react-context-menu": "npm:@radix-ui/react-context-menu@2.2.6",
    "@radix-ui/react-dialog": "npm:@radix-ui/react-dialog@1.1.6",
