DATABASE_URL=postgresql://postgres:postgres@localhost:5432/study_sprint
JWT_SECRET=replace-me-with-a-long-random-string
PORT=4000
CLIENT_ORIGIN=http://localhost:5173

# Optional: OpenRouter free-tier key for the AI syllabus parser (#22).
# Get one at https://openrouter.ai/keys — the default models are free.
# OPENROUTER_MODEL accepts a single id or a comma-separated fallback chain
# (OpenRouter tries each in order on 429/503/etc). Leave unset to use the
# in-code default chain.
OPENROUTER_API_KEY=
# OPENROUTER_MODEL=openrouter/free

# Optional: Google Calendar integration (#13).
# Create an OAuth 2.0 Client ID (Web application) in Google Cloud Console,
# add http://localhost:4000/api/integrations/google/callback as an
# authorized redirect URI, and enable the Google Calendar API.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/integrations/google/callback
