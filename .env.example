# ============================================================================
# SUPABASE (Frontend Client)
# ============================================================================
# Get these from the Supabase dashboard under Project Settings → API Keys.
# Publishable keys (sb_publishable_…) are safe to ship in the client bundle —
# RLS policies enforce per-user access on the server side. Edge Functions are
# reachable at `${VITE_SUPABASE_URL}/functions/v1/<function-name>` and the
# auth header is forwarded automatically.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_…

# Secret key (sb_secret_…) — only needed for `deno task test:setup`
# (the e2e fixture bootstrap). Never used by the running app or the
# running test suite. Pull from Supabase dashboard → Project Settings →
# API Keys, "Secret key" row. .env is gitignored.
# SUPABASE_SECRET_KEY=

# ============================================================================
# AUTHENTICATION
# ============================================================================
# Google OAuth is configured in Supabase → Authentication → Providers → Google.
# No environment variables needed here — Supabase handles the redirect flow.
# Make sure the OAuth app is configured in Google Cloud Console with the
# redirect URI: https://your-project-ref.supabase.co/auth/v1/callback?provider=google

# ============================================================================
# OPENROUTER (LLM Gateway for Edge Functions)
# ============================================================================
# Required for the `syllabus-parse` Edge Function, which uses OpenRouter to
# parse syllabus documents via Claude. Get your API key from:
# https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-…

# Optional: specify which models to use (default: openrouter/free).
# Can be a single model ID or comma-separated chain (max 3).
# Examples:
#   - Single: anthropic/claude-3-5-sonnet
#   - Chain: anthropic/claude-3-5-sonnet,anthropic/claude-3-opus,openrouter/free
# OPENROUTER_MODEL=openrouter/free

# ============================================================================
# ANALYTICS
# ============================================================================
# Vercel Analytics is automatically enabled in production deployments.
# No configuration needed — it tracks Core Web Vitals and page views out of the box.
# View metrics at: https://vercel.com/dashboard/analytics
