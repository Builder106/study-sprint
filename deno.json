    "react": "npm:react@18.3.1",
    "react-day-picker": "npm:react-day-picker@8.10.1",
    "react-dnd": "npm:react-dnd@16.0.1",
    "react-dnd-html5-backend": "npm:react-dnd-html5-backend@16.0.1",
    "react-dom": "npm:react-dom@18.3.1",
    "react-hook-form": "npm:react-hook-form@7.55.0",
    "react-markdown": "npm:react-markdown@10.1.0",
    "react-popper": "npm:react-popper@2.3.0",
    "react-resizable-panels": "npm:react-resizable-panels@2.1.7",
    "react-responsive-masonry": "npm:react-responsive-masonry@2.7.1",
    "react-router": "npm:react-router@7.13.0",
    "react-slick": "npm:react-slick@0.31.0",
    "recharts": "npm:recharts@2.15.2",
    "sonner": "npm:sonner@2.0.3",
    "tailwind-merge": "npm:tailwind-merge@3.2.0",
    "tw-animate-css": "npm:tw-animate-css@1.3.8",
    "vaul": "npm:vaul@1.1.2",

    "@playwright/test": "npm:@playwright/test@^1.59.1",
    "@tailwindcss/typography": "npm:@tailwindcss/typography@^0.5.19",
    "@tailwindcss/vite": "npm:@tailwindcss/vite@4.1.12",
    "@types/node": "npm:@types/node@^25.6.0",
    "@types/react": "npm:@types/react@^18.3.12",
    "@types/react-dom": "npm:@types/react-dom@^18.3.1",
    "@vitejs/plugin-react": "npm:@vitejs/plugin-react@4.7.0",
    "playwright-bdd": "npm:playwright-bdd@^8.5.0",
    "tailwindcss": "npm:tailwindcss@4.1.12",
    "typescript": "npm:typescript@^6.0.3",
    "vite": "npm:vite@6.3.5",
    "supabase": "npm:supabase@^2"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "types": ["vite/client"]
  },
  "nodeModulesDir": "auto",
  "fmt": {
    "useTabs": false,
    "indentWidth": 2,
    "lineWidth": 100,
    "semiColons": true,
    "singleQuote": false,
    "include": [
      "supabase/functions/syllabus-parse",
      "supabase/functions/google-calendar",
      "e2e/setup",
      "e2e/steps",
      "deno.json",
      "vite.config.ts",
      "playwright.config.ts",
      "playwright.demo.config.ts"
    ],
    "exclude": [
      "node_modules",
      "dist",
      ".features-gen",
      ".features-gen-demo",
      "test-results",
      "playwright-report"
    ]
  },
  "lint": {
    "exclude": [
      "node_modules",
      "dist",
      ".features-gen",
      ".features-gen-demo",
      "test-results",
      "playwright-report"
    ]
  },
  "exclude": [
    "node_modules",
    "dist",
    ".features-gen",
    ".features-gen-demo",
    "test-results",
    "playwright-report",
    "supabase/functions"
  ]
}
